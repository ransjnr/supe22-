# ─────────────────────────────────────────────────────────────
# SANITY CMS
# Get these from https://sanity.io → your project → API settings
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity write token — for seed script & server mutations
# Create at: Sanity Dashboard → API → Tokens → "Editor" permission
SANITY_API_TOKEN=your_sanity_editor_token_here

# ─────────────────────────────────────────────────────────────
# RESEND — Transactional email + Newsletter subscribers
# Get API key from https://resend.com → API Keys
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend Audience ID for newsletter subscribers
# Create at: Resend → Audiences → New Audience → copy ID
RESEND_AUDIENCE_ID=your_audience_id_here

# Email that receives contact form submissions
CONTACT_NOTIFICATION_EMAIL=oppong.rans@gmail.com

# Verified sender email (must be a verified domain in Resend)
# During testing before domain verification use: onboarding@resend.dev
NEXT_PUBLIC_FROM_EMAIL=hello@ransford.tech

# ─────────────────────────────────────────────────────────────
# SITE
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ransford.tech

# ─────────────────────────────────────────────────────────────
# TAWK.TO — Live Chat Widget (optional)
# Get from: https://dashboard.tawk.to → Administration → Chat Widget
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# ─────────────────────────────────────────────────────────────
# GOOGLE ANALYTICS (optional)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
